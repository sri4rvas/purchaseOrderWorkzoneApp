    "node": "^20 || ^22"
  },
  "dependencies": {
    "@cap-js-community/odata-v2-adapter": "^1.13.6",
    "@cap-js/hana": "^2",
    "@sap/cds": "^9.9.1",
    "@sap/eslint-plugin-ui5-jsdocs": "^2.0.5",
    "@sap/xsenv": "^6.2.1",
